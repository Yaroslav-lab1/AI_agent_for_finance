POSTGRES_DB=finance_agent
POSTGRES_USER=finance_agent
POSTGRES_PASSWORD=finance_agent_dev_password
DATABASE_URL=postgresql+asyncpg://finance_agent:finance_agent_dev_password@postgres:5432/finance_agent
JWT_SECRET=dev-secret-change-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=http://localhost:5173
LLM_PROVIDER=ollama
LLM_MODEL=qwen3.5:9b
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_REQUEST_TIMEOUT_SECONDS=120
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REQUEST_TIMEOUT_SECONDS=60
OCR_LANG=rus+eng
MAX_UPLOAD_SIZE_MB=10
ENVIRONMENT=development
